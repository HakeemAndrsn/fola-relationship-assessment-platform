ame\\\":\\\"mx-auto max-w-6xl px-6 py-4 flex items-center justify-between\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L15\\\",null,{\\\"href\\\":\\\"/\\\",\\\"children\\\":[[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-white tracking-tight font-serif\\\",\\\"children\\\":\\\"LoveBetter\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-[10px] text-[#a0aec0] tracking-wide font-sans\\\",\\\"children\\\":\\\"Relationship Growth Readiness Assessment\\\"}]]}],[\\\"$\\\",\\\"nav\\\",null,{\\\"className\\\":\\\"hidden sm:flex items-center gap-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L15\\\",null,{\\\"href\\\":\\\"/the-uncommon-practice\\\",\\\"className\\\":\\\"text-sm text-[#a0aec0] hover:text-white transition-colors font-sans\\\",\\\"children\\\":\\\"The Uncommon Practice\\\"}],[\\\"$\\\",\\\"$L15\\\",null,{\\\"href\\\":\\\"/assessment\\\",\\\"className\\\":\\\"inline-flex items-center gap-2 bg-[#d4af37] text-[#1a365d] px-5 py-2.5 rounded-lg text-sm font-bold font-sans hover:bg-[#e4bf47] transition-all hover:shadow-lg hover:shadow-[#d4af37]/20\\\",\\\"children\\\":\\\"Start Assessment\\\"}]]}]]}]}],[\\\"$\\\",\\\"main\\\",null,{\\\"className\\\":\\\"pt-32 pb-20 px-6\\\",\\\"children\\\":[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"mx-auto max-w-3xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L15\\\",null,{\\\"href\\\":\\\"/the-uncommon-practice\\\",\\\"className\\\":\\\"inline-flex items-center gap-2 text-sm text-[#a0aec0] hover:text-white transition-colors font-sans mb-8\\\",\\\"children\\\":[[\\\"$\\\",\\\"svg\\\",null,{\\\"className\\\":\\\"w-4 h-4\\\",\\\"fill\\\":\\\"none\\\",\\\"viewBox\\\":\\\"0 0 24 24\\\",\\\"stroke\\\":\\\"currentColor\\\",\\\"strokeWidth\\\":2,\\\"children\\\":[\\\"$\\\",\\\"path\\\",null,{\\\"strokeLinecap\\\":\\\"round\\\",\\\"strokeLinejoin\\\":\\\"round\\\",\\\"d\\\":\\\"M11 17l-5-5m0 0l5-5m-5 5h12\\\"}]}],\\\"Back to The Uncommon Practice\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mb-12\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-3 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-xs font-semibold text-[#d4af37] bg-[#d4af37]/10 px-2.5 py-1 rounded-full font-sans\\\",\\\"children\\\":\\\"Trauma\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-xs text-[#718096] font-sans\\\",\\\"children\\\":\\\"October 25, 2025\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-xs text-[#718096] font-sans\\\",\\\"children\\\":\\\"13 min read\\\"}]]}],[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl sm:text-4xl lg:text-5xl font-bold text-white font-serif leading-[1.15]\\\",\\\"children\\\":\\\"Trauma Is Not What Happened to You\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-3 text-lg text-[#d4af37]/70 font-serif italic\\\",\\\"children\\\":\\\"It's what happened inside you as a result. And it's living in your relationship right now.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-6 flex items-center gap-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-10 h-10 rounded-full bg-[#d4af37]/20 border border-[#d4af37]/30 flex items-center justify-center\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-sm font-bold text-[#d4af37] font-serif\\\",\\\"children\\\":\\\"H\\\"}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-sm font-semibold text-white font-sans\\\",\\\"children\\\":\\\"Hakeem Lesolang\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs text-[#718096] font-sans\\\",\\\"children\\\":\\\"Hypnotherapist \\u0026 Peak Performance Coach\\\"}]]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-16 h-px bg-[#d4af37]/30 mb-12\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-custom\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"Dr. Gabor Maté said it best: \\\\\\\"Trauma is not what happens to you. It's what happens inside you as a result of what happens to you.\\\\\\\"\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"2\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"And that \\u003cem class=\\\\\\\"text-[#d4af37]/80\\\\\\\"\\u003einside part\\u003c/em\\u003e — the neural rewiring, the defensive adaptations, the subconscious beliefs about safety, worthiness, and trust — doesn't stay neatly contained in your individual psychology. It shows up every day in your relationship. In the fights that don't make sense. In the distance that has no explanation. In the patterns that repeat no matter how many times you promise yourself \\\\\\\"never again.\\\\\\\"\\\"}}],[\\\"$\\\",\\\"h2\\\",\\\"4\\\",{\\\"className\\\":\\\"text-2xl font-bold text-white font-serif mt-12 mb-4\\\",\\\"children\\\":\\\"The ACE Connection\\\"}],[\\\"$\\\",\\\"p\\\",\\\"6\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"The Adverse Childhood Experiences (ACE) study — conducted by Dr. Vincent Felitti and Dr. Robert Anda with over 17,000 participants — remains one of the most significant public health studies ever conducted. It found a direct, dose-response relationship between childhood adversity and adult health outcomes, including relationship functioning.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"8\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"The ten ACE categories include physical, emotional, and sexual abuse; physical and emotional neglect; and household dysfunction (domestic violence, substance abuse, mental illness, parental separation, incarcerated family member).\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"10\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"Here's what matters for your relationship: \\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003ea person with an ACE score of 4 or higher is significantly more likely to experience difficulty with emotional regulation, trust, and intimate connection in adulthood.\\u003c/strong\\u003e Not because they're damaged. Because their nervous system adapted to an environment of threat, and those adaptations persist long after the threat is gone.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"12\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"In the FOLA assessment, we screen for ACEs not to diagnose or label, but to illuminate. Because you cannot navigate a pattern you cannot see.\\\"}}],[\\\"$\\\",\\\"h2\\\",\\\"14\\\",{\\\"className\\\":\\\"text-2xl font-bold text-white font-serif mt-12 mb-4\\\",\\\"children\\\":\\\"How Trauma Lives in the Body\\\"}],[\\\"$\\\",\\\"p\\\",\\\"16\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"Dr. Bessel van der Kolk's landmark work, \\u003cem class=\\\\\\\"text-[#d4af37]/80\\\\\\\"\\u003eThe Body Keeps the Score,\\u003c/em\\u003e fundamentally changed how we understand trauma. His research shows that trauma is stored not primarily in narrative memory (the story of what happened) but in the body — in muscle tension, breathing patterns, postural habits, and autonomic nervous system settings.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"18\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"This means you can go to talk therapy for years, develop a sophisticated understanding of your childhood, and still flinch when your partner raises their voice. Because the body hasn't received the memo. The implicit memory system — the body's record — still carries the encoding.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"20\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"In my hypnotherapy practice, this is where the deep work happens. We bypass the narrative mind and go directly to the somatic encoding. \\\\\\\"Where do you feel it in your body when your partner criticises you?\\\\\\\" The answer is always specific: the chest, the throat, the stomach. And when we follow that sensation back in time — using age regression techniques — we almost always arrive at a scene from childhood where that exact sensation was first encoded.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"22\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"The goal isn't to relive the trauma. It's to resource it. To give the younger self what they needed at the time — safety, protection, validation — and to allow the nervous system to complete the defensive response it was never able to complete. Running if you needed to run. Saying no if you needed to say no. Crying if you were never allowed to cry.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"24\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"When this completion happens, the present-day trigger loses its charge. Not because you've forgotten. Because your nervous system no longer needs to protect you from something that already happened.\\\"}}],[\\\"$\\\",\\\"h2\\\",\\\"26\\\",{\\\"className\\\":\\\"text-2xl font-bold text-white font-serif mt-12 mb-4\\\",\\\"children\\\":\\\"The Four Trauma Responses in Relationships\\\"}],[\\\"$\\\",\\\"p\\\",\\\"28\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"Pete Walker's work on Complex PTSD identifies four primary trauma responses: fight, flight, freeze, and fawn. Every person has a dominant response, and every relationship has a pattern built on the interaction between two trauma responses.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"30\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003eFight:\\u003c/strong\\u003e The partner who becomes aggressive, critical, or controlling under stress. Their nervous system learned early that the best defense is a good offense. In the relationship, this looks like escalation, blame, and a need to dominate the narrative of the conflict. Underneath: terror of helplessness.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"32\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003eFlight:\\u003c/strong\\u003e The partner who stays perpetually busy, avoids emotional conversations, or literally leaves the room during conflict. Their nervous system learned that safety lies in distance. In the relationship, this looks like workaholism, distraction, and emotional unavailability. Underneath: terror of engulfment.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"34\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003eFreeze:\\u003c/strong\\u003e The partner who shuts down, dissociates, or goes blank during emotional intensity. Their nervous system learned that the safest response to overwhelming threat is to disappear internally. In the relationship, this looks like stonewalling, emotional flatness, and an inability to respond in the moment. Underneath: terror of annihilation.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"36\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003eFawn:\\u003c/strong\\u003e The partner who over-accommodates, people-pleases, and abandons their own needs to maintain the relationship. Their nervous system learned that safety comes from making the other person happy. In the relationship, this looks like chronic self-sacrifice, difficulty with boundaries, and eventual explosive resentment. Underneath: terror of abandonment.\\\"}}],[\\\"$\\\",\\\"h2\\\",\\\"38\\\",{\\\"className\\\":\\\"text-2xl font-bold text-white font-serif mt-12 mb-4\\\",\\\"children\\\":\\\"The Dance of Two Wounded Nervous Systems\\\"}],[\\\"$\\\",\\\"p\\\",\\\"40\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"Every couple is a system composed of two individuals, each carrying their own trauma history, their own dominant response, and their own set of triggers. The relational \\\\\\\"dance\\\\\\\" is the predictable pattern that emerges when these two systems interact under stress.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"44\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"Fight-flight: One partner escalates, the other runs. The pursuer-distancer cycle.\\u003cbr /\\u003eFight-freeze: One partner rages, the other shuts down. The attacker-stonewaller cycle.\\u003cbr /\\u003eFawn-fight: One partner over-accommodates until they explode, shocking the other. The martyr-villain cycle.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"46\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"These dances are not chosen. They are emergent properties of two nervous systems doing what they learned to do. And they will continue, automatically and indefinitely, until both partners develop awareness of their own patterns and compassion for their partner's.\\\"}}],[\\\"$\\\",\\\"h2\\\",\\\"48\\\",{\\\"className\\\":\\\"text-2xl font-bold text-white font-serif mt-12 mb-4\\\",\\\"children\\\":\\\"The Way Forward\\\"}],[\\\"$\\\",\\\"p\\\",\\\"50\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003e1. Know your ACE score.\\u003c/strong\\u003e Not as a diagnosis, but as a map. Understanding the terrain of your childhood adversity helps you predict which relational situations will activate your nervous system. The FOLA assessment includes an ACE-informed screening specifically for this purpose.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"52\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003e2. Identify your dominant trauma response.\\u003c/strong\\u003e Are you a fighter, flighter, freezer, or fawner? And what is your partner's? Once you can name the dance, you can begin to change it.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"54\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003e3. Practise window of tolerance expansion.\\u003c/strong\\u003e Dr. Daniel Siegel's concept of the \\\\\\\"window of tolerance\\\\\\\" describes the zone of autonomic arousal within which you can function effectively. Trauma narrows this window. Healing widens it. Practices like breathwork, bilateral stimulation, yoga, and — yes — hypnotherapy all serve to expand your capacity to stay present during relational stress.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"56\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003e4. Seek trauma-informed support.\\u003c/strong\\u003e Not all therapy is created equal. If trauma is a significant factor in your relationship, you need a therapist who understands it somatically, not just cognitively. EMDR, somatic experiencing, EFT, and clinical hypnotherapy are all evidence-based modalities that address trauma at the level where it actually lives.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"58\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003cstrong class=\\\\\\\"text-white font-semibold\\\\\\\"\\u003e5. Lead with compassion — for yourself and your partner.\\u003c/strong\\u003e You are not your trauma response. Your partner is not their trauma response. You are two people who survived difficult things and developed brilliant strategies to keep yourselves safe. Those strategies are now outdated. They need updating, not condemning.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"60\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"The uncommon practice is this: to look at your own wounded patterns with honesty, to look at your partner's with compassion, and to commit — together — to building something safer than anything either of you has known.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"62\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"That is not naive optimism. That is neuroplasticity. The brain that was shaped by fear can be reshaped by love. Not romantic love — though that helps. But the love that shows up, stays present, and does the work even when it's hard.\\\"}}],[\\\"$\\\",\\\"p\\\",\\\"64\\\",{\\\"className\\\":\\\"text-[#cbd5e0] font-sans leading-[1.85] mb-6 text-base\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"Especially when it's hard.\\\"}}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-16 rounded-2xl border border-[#d4af37]/30 bg-gradient-to-b from-[#d4af37]/10 to-transparent p-8 text-center\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-xl font-bold text-white font-serif\\\",\\\"children\\\":\\\"Ready to talk about what you just read?\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-2 text-sm text-[#a0aec0] font-sans max-w-md mx-auto\\\",\\\"children\\\":\\\"Book a free discovery call with Hakeem Lesolang. No pressure. No pitch. Just an honest conversation about where you are and where you want to be.\\\"}],[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"https://calendly.com/folasessions/discovery-call\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"mt-6 inline-flex items-center gap-2 bg-[#d4af37] text-[#1a365d] px-6 py-3 rounded-xl text-sm font-bold font-sans hover:bg-[#e4bf47] transition-all hover:shadow-lg hover:shadow-[#d4af37]/20\\\",\\\"children\\\":[\\\"Book Your Free Discovery Call\\\",[\\\"$\\\",\\\"svg\\\",null,{\\\"className\\\":\\\"w-4 h-4\\\",\\\"fill\\\":\\\"none\\\",\\\"viewBox\\\":\\\"0 0 24 24\\\",\\\"stroke\\\":\\\"currentColor\\\",\\\"strokeWidth\\\":2.5,\\\"children\\\":[\\\"$\\\",\\\"path\\\",null,{\\\"strokeLinecap\\\":\\\"round\\\",\\\"strokeLinejoin\\\":\\\"round\\\",\\\"d\\\":\\\"M13 7l5 5m0 0l-5 5m5-5H6\\\"}]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-full h-px bg-white/10 my-16\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid gap-4 sm:grid-cols-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L15\\\",null,{\\\"href\\\":\\\"/the-uncommon-practice/adhd-and-love-the-conversation-nobody-is-having\\\",\\\"className\\\":\\\"group rounded-xl border border-white/10 bg-white/5 p-5 hover:border-[#d4af37]/30 transition-all\\\",\\\"children