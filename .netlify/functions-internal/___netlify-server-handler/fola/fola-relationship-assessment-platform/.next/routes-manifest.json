{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/the-uncommon-practice/[slug]",
      "regex": "^/the\\-uncommon\\-practice/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/the\\-uncommon\\-practice/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/angels",
      "regex": "^/angels(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/angels(?:/)?$"
    },
    {
      "page": "/assessment",
      "regex": "^/assessment(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/assessment(?:/)?$"
    },
    {
      "page": "/bundle-payment",
      "regex": "^/bundle\\-payment(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/bundle\\-payment(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/individual-assessment",
      "regex": "^/individual\\-assessment(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/individual\\-assessment(?:/)?$"
    },
    {
      "page": "/individual-report",
      "regex": "^/individual\\-report(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/individual\\-report(?:/)?$"
    },
    {
      "page": "/linkedin-callback",
      "regex": "^/linkedin\\-callback(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/linkedin\\-callback(?:/)?$"
    },
    {
      "page": "/privacy",
      "regex": "^/privacy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy(?:/)?$"
    },
    {
      "page": "/report",
      "regex": "^/report(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/report(?:/)?$"
    },
    {
      "page": "/store",
      "regex": "^/store(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/store(?:/)?$"
    },
    {
      "page": "/terms",
      "regex": "^/terms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms(?:/)?$"
    },
    {
      "page": "/the-uncommon-practice",
      "regex": "^/the\\-uncommon\\-practice(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/the\\-uncommon\\-practice(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
